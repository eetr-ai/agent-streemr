{
  "name": "@eetr/agent-streemr",
  "version": "0.1.4",
  "description": "Reusable Socket.io + LangChain agent plumbing: protocol types, socket listener, local-tool registry, and stream adapter.",
  "author": "Juan Alberto Lopez Cavallotti",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./protocol/events": {
      "types": "./dist/protocol/events.d.ts",
      "import": "./dist/protocol/events.js",
      "require": "./dist/cjs/protocol/events.js"
    },
    "./protocol/localTool": {
      "types": "./dist/protocol/localTool.d.ts",
      "import": "./dist/protocol/localTool.js",
      "require": "./dist/cjs/protocol/localTool.js"
    },
    "./protocol/stream": {
      "types": "./dist/protocol/stream.d.ts",
      "import": "./dist/protocol/stream.js",
      "require": "./dist/cjs/protocol/stream.js"
    },
    "./server/queue": {
      "types": "./dist/server/queue.d.ts",
      "import": "./dist/server/queue.js",
      "require": "./dist/cjs/server/queue.js"
    },
    "./server/registry": {
      "types": "./dist/server/registry.d.ts",
      "import": "./dist/server/registry.js",
      "require": "./dist/cjs/server/registry.js"
    },
    "./server/adapter": {
      "types": "./dist/server/adapter.d.ts",
      "import": "./dist/server/adapter.js",
      "require": "./dist/cjs/server/adapter.js"
    },
    "./server/listener": {
      "types": "./dist/server/listener.d.ts",
      "import": "./dist/server/listener.js",
      "require": "./dist/cjs/server/listener.js"
    },
    "./langchain/localTool": {
      "types": "./dist/langchain/localTool.d.ts",
      "import": "./dist/langchain/localTool.js",
      "require": "./dist/cjs/langchain/localTool.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json && tsc --project tsconfig.build.cjs.json && node --input-type=commonjs -e \"require('fs').writeFileSync('dist/cjs/package.json', JSON.stringify({type:'commonjs'}, null, 2))\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.0",
    "socket.io": ">=4.0.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@langchain/core": { "optional": true },
    "socket.io": { "optional": true },
    "zod": { "optional": true }
  },
  "devDependencies": {
    "@langchain/core": "^1.1.30",
    "@types/node": "^22.0.0",
    "socket.io": "^4.8.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "zod": "^3.25.0"
  },
  "keywords": [
    "langchain",
    "socket.io",
    "agent",
    "streaming",
    "local-tool",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/eetr-ai/agent-streemr.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
