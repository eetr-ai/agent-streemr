{
  "name": "@eetr/agent-streemr",
  "version": "0.1.0",
  "description": "Reusable Socket.io + LangChain agent plumbing: protocol types, socket listener, local-tool registry, and stream adapter.",
  "author": "Juan Alberto Lopez Cavallotti",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./protocol/events": {
      "import": "./dist/protocol/events.js",
      "require": "./dist/protocol/events.cjs",
      "types": "./dist/protocol/events.d.ts"
    },
    "./protocol/localTool": {
      "import": "./dist/protocol/localTool.js",
      "require": "./dist/protocol/localTool.cjs",
      "types": "./dist/protocol/localTool.d.ts"
    },
    "./protocol/stream": {
      "import": "./dist/protocol/stream.js",
      "require": "./dist/protocol/stream.cjs",
      "types": "./dist/protocol/stream.d.ts"
    },
    "./server/queue": {
      "import": "./dist/server/queue.js",
      "require": "./dist/server/queue.cjs",
      "types": "./dist/server/queue.d.ts"
    },
    "./server/registry": {
      "import": "./dist/server/registry.js",
      "require": "./dist/server/registry.cjs",
      "types": "./dist/server/registry.d.ts"
    },
    "./server/adapter": {
      "import": "./dist/server/adapter.js",
      "require": "./dist/server/adapter.cjs",
      "types": "./dist/server/adapter.d.ts"
    },
    "./server/listener": {
      "import": "./dist/server/listener.js",
      "require": "./dist/server/listener.cjs",
      "types": "./dist/server/listener.d.ts"
    },
    "./langchain/localTool": {
      "import": "./dist/langchain/localTool.js",
      "require": "./dist/langchain/localTool.cjs",
      "types": "./dist/langchain/localTool.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.0",
    "socket.io": ">=4.0.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@langchain/core": { "optional": true },
    "socket.io": { "optional": true },
    "zod": { "optional": true }
  },
  "devDependencies": {
    "@langchain/core": "^1.1.30",
    "@types/node": "^22.0.0",
    "socket.io": "^4.8.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "zod": "^3.25.0"
  },
  "keywords": [
    "langchain",
    "socket.io",
    "agent",
    "streaming",
    "local-tool",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/eetr/agent-streemr.git"
  }
}
