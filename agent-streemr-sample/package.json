{
  "name": "@eetr/agent-streemr-sample",
  "version": "0.1.0",
  "description": "Reference implementation using @eetr/agent-streemr — a minimal Socket.io + LangChain agent server.",
  "author": "Juan Alberto Lopez Cavallotti",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@eetr/agent-streemr": "*",
    "@eetr/agent-streemr-react": "*",
    "@langchain/core": "^1.1.30",
    "@langchain/langgraph": "^1.2.0",
    "@langchain/openai": "^1.2.12",
    "express": "^4.21.0",
    "socket.io": "^4.8.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
